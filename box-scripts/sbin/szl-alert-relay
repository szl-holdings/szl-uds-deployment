#!/usr/bin/env python3
"""
szl-alert-relay — tiny localhost relay that turns a Slack-format webhook
payload into a CLEAN ntfy push.

WHY: several GitHub Actions alert steps (e.g. szl-holdings/a11oy
.github/workflows/rekor-recheck.yml + release-receipt-verify.yml, and
szl-holdings/platform .github/workflows/post-deploy-smoke.yml) POST a Slack
incoming-webhook body to whatever `SLACK_WEBHOOK_URL` points at. The team's
only watched push channel is the ntfy topic in /etc/a11oy-uptime.env. ntfy
accepts that JSON and returns HTTP 200, but it does NOT understand the Slack
schema — it renders the raw JSON wrapper as the message body, which is ugly for
an urgent page. This relay sits behind the existing nginx, flattens the Slack
payload into clean plain text (`.text` plus any `attachments[]` fields/footer),
cleans it up (per-line de-indent, Slack emoji shortcodes -> unicode, strip
`*bold*` markers, unwrap `<url|label>` links, drop ``` fences), and republishes
it as plain text via the shared notifier /usr/local/sbin/a11oy-uptime-notify
(which reads NTFY_URL from /etc/a11oy-uptime.env), so the page reads as clean
text.

CONTRACT:
  POST  /relay/ntfy/<RELAY_TOKEN>   body = Slack webhook JSON (`{"text": ...}`
        and/or `{"attachments": [...]}`)  -> 200 on successful republish, 502 if
        the notifier failed, 400 on a body with no usable text, 404 on a
        wrong/absent token (token is never echoed).
  GET   /relay/health               -> 200 "ok" (no token; for nginx/smoke).

CONFIG (env file, default /etc/szl-alert-relay.env; real env wins):
  RELAY_TOKEN=<unguessable>     # REQUIRED; must match the path segment
  RELAY_PORT=9099              # listen port on 127.0.0.1 (default 9099)
  NOTIFY_CMD=/usr/local/sbin/a11oy-uptime-notify   # text arrives on its stdin
  NOTIFY_TITLE=Rekor receipt re-check               # ntfy Title header
  NTFY_PRIORITY=high           # passed through to the notifier

It is deliberately FAIL-LOUD on delivery: if the notifier exits non-zero the
relay returns 502 so the calling workflow's 2xx gate surfaces the problem.
"""
import json
import os
import re
import subprocess
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

ENV_FILE = os.environ.get("SZL_ALERT_RELAY_ENV", "/etc/szl-alert-relay.env")


def load_env(path):
    """Load KEY=VALUE lines without clobbering the real environment."""
    if not os.path.isfile(path):
        return
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as fh:
            for raw in fh:
                line = raw.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, _, val = line.partition("=")
                key = key.strip()
                val = val.strip()
                if len(val) >= 2 and val[0] == val[-1] and val[0] in ("'", '"'):
                    val = val[1:-1]
                if key and key not in os.environ:
                    os.environ[key] = val
    except OSError:
        pass


load_env(ENV_FILE)

RELAY_TOKEN = os.environ.get("RELAY_TOKEN", "").strip()
RELAY_PORT = int(os.environ.get("RELAY_PORT", "9099"))
NOTIFY_CMD = os.environ.get("NOTIFY_CMD", "/usr/local/sbin/a11oy-uptime-notify")
NOTIFY_TITLE = os.environ.get("NOTIFY_TITLE", "Rekor receipt re-check")
NTFY_PRIORITY = os.environ.get("NTFY_PRIORITY", "high")

# Slack emoji shortcodes seen in the alert payloads -> unicode.
EMOJI = {
    ":rotating_light:": "\U0001F6A8",  # 🚨
    ":white_check_mark:": "\u2705",     # ✅
    ":warning:": "\u26A0\uFE0F",        # ⚠️
    ":x:": "\u274C",                     # ❌
    ":fire:": "\U0001F525",             # 🔥
}

_BOLD = re.compile(r"\*(.+?)\*")
_EMOJI = re.compile(r":[a-z0-9_+\-]+:")
# Slack link markup: <url|label> -> "label (url)"; <url> -> "url".
_LINK_LABEL = re.compile(r"<([^|>]+)\|([^>]+)>")
_LINK_BARE = re.compile(r"<(https?://[^>]+)>")
_FENCE = re.compile(r"```")


def _stringy(val):
    return isinstance(val, str) and val.strip() != ""


def build_text(data):
    """Flatten a Slack webhook payload into a single plain-text block.

    Handles the simple `{"text": ...}` shape (rekor-recheck /
    release-receipt-verify) and the richer `{"text": ..., "attachments": [...]}`
    shape (post-deploy-smoke) by appending each attachment's title/text, its
    `fields[]` as "Title: value" lines, and its footer.
    """
    parts = []
    if _stringy(data.get("text")):
        parts.append(data["text"])

    attachments = data.get("attachments")
    if isinstance(attachments, list):
        for att in attachments:
            if not isinstance(att, dict):
                continue
            if _stringy(att.get("pretext")):
                parts.append(att["pretext"])
            if _stringy(att.get("title")):
                parts.append(att["title"])
            if _stringy(att.get("text")):
                parts.append(att["text"])
            fields = att.get("fields")
            if isinstance(fields, list):
                for fld in fields:
                    if not isinstance(fld, dict):
                        continue
                    ftitle = (fld.get("title") or "").strip()
                    fvalue = (fld.get("value") or "").strip()
                    if ftitle and fvalue:
                        sep = "\n" if "\n" in fvalue else " "
                        parts.append("%s:%s%s" % (ftitle, sep, fvalue))
                    elif fvalue:
                        parts.append(fvalue)
                    elif ftitle:
                        parts.append(ftitle)
            if _stringy(att.get("footer")):
                parts.append(att["footer"])

    return "\n".join(parts)


def clean_text(text):
    """Turn Slack mrkdwn into a clean plain-text ntfy body."""
    # Unwrap Slack link markup before de-indenting.
    text = _LINK_LABEL.sub(r"\2 (\1)", text)
    text = _LINK_BARE.sub(r"\1", text)
    # Drop ``` code fences (ntfy plaintext won't render them).
    text = _FENCE.sub("", text)
    # De-indent each line (the workflow heredoc carries YAML leading spaces).
    lines = [ln.strip() for ln in text.replace("\r\n", "\n").split("\n")]
    s = "\n".join(lines).strip()
    # Collapse 3+ consecutive blank lines down to a single blank line.
    s = re.sub(r"\n{3,}", "\n\n", s)
    # Strip *bold* markers (ntfy plaintext won't render them).
    s = _BOLD.sub(r"\1", s)
    # Map known emoji shortcodes; leave unknown ones untouched.
    s = _EMOJI.sub(lambda m: EMOJI.get(m.group(0), m.group(0)), s)
    return s


def republish(text):
    """Pipe the cleaned text to the shared notifier. Returns True on success."""
    env = dict(os.environ)
    env["NOTIFY_TITLE"] = NOTIFY_TITLE
    env["NTFY_PRIORITY"] = NTFY_PRIORITY
    try:
        proc = subprocess.run(
            [NOTIFY_CMD],
            input=text.encode("utf-8"),
            env=env,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=30,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        sys.stderr.write("[alert-relay] notifier invocation failed: %s\n" % exc)
        return False
    if proc.stdout:
        sys.stderr.write("[alert-relay] notifier: %s\n"
                         % proc.stdout.decode("utf-8", "replace").strip())
    return proc.returncode == 0


class Handler(BaseHTTPRequestHandler):
    server_version = "szl-alert-relay/1.1"

    def _send(self, code, body=""):
        payload = body.encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        try:
            self.wfile.write(payload)
        except BrokenPipeError:
            pass

    def log_message(self, fmt, *args):  # quieter, go to stderr (journald)
        sys.stderr.write("[alert-relay] %s - %s\n"
                         % (self.address_string(), fmt % args))

    def do_GET(self):
        if self.path == "/relay/health":
            self._send(200, "ok")
        else:
            self._send(404, "not found")

    def do_POST(self):
        if not RELAY_TOKEN:
            sys.stderr.write("[alert-relay] RELAY_TOKEN not configured; refusing\n")
            self._send(503, "relay not configured")
            return
        expected = "/relay/ntfy/" + RELAY_TOKEN
        if self.path != expected:
            self._send(404, "not found")
            return
        try:
            length = int(self.headers.get("Content-Length", "0"))
        except ValueError:
            length = 0
        if length <= 0 or length > 1_000_000:
            self._send(400, "bad request")
            return
        raw = self.rfile.read(length)
        try:
            data = json.loads(raw.decode("utf-8"))
        except (ValueError, AttributeError):
            data = None
        if not isinstance(data, dict):
            self._send(400, "bad request")
            return
        text = build_text(data)
        if not text.strip():
            self._send(400, "missing .text")
            return
        if republish(clean_text(text)):
            self._send(200, "ok")
        else:
            self._send(502, "republish failed")


def main():
    if not RELAY_TOKEN:
        sys.stderr.write(
            "[alert-relay] WARNING: RELAY_TOKEN is empty (set it in %s); "
            "all POSTs will be refused with 503 until it is set.\n" % ENV_FILE)
    httpd = ThreadingHTTPServer(("127.0.0.1", RELAY_PORT), Handler)
    sys.stderr.write("[alert-relay] listening on 127.0.0.1:%d -> %s\n"
                     % (RELAY_PORT, NOTIFY_CMD))
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
