#!/usr/bin/env bash
# Copyright 2026 SZL Holdings
# SPDX-License-Identifier: Apache-2.0
#
# vault-keystore-offbox-backup — push the latest local Vault keystore snapshot
# (the encrypted Vault barrier + its matching Shamir unseal shares, produced by
# scripts/vault-keystore-backup.sh under /root/vault-keystore-backup) to DURABLE
# OFF-BOX storage, encrypted at rest, with retention/rotation — so the receipt
# signing key survives the loss of the box itself, not just a cluster recreate.
#
# WHY THIS EXISTS
# scripts/vault-keystore-backup.sh already snapshots the barrier+shares, but the
# snapshot lives ONLY host-local under /root/vault-keystore-backup. A `k3d
# cluster delete` is survivable, but if the box disk dies the snapshot — and with
# it the szl-receipts Transit signing key and every receipt's verifiability — is
# gone for good. This job closes that single-point-of-failure by shipping an
# encrypted copy off the box on a schedule.
#
# SECURITY (read before configuring)
# The snapshot contains the unseal share(s) + root token AND the encrypted
# barrier — i.e. EVERYTHING needed to use the signing key. Therefore:
#   * It is ALWAYS encrypted on this box BEFORE it leaves (GPG). The plaintext
#     tar is built in a root-only 0700 temp dir and shredded; only the
#     `.tar.gz.gpg` ciphertext is ever shipped.
#   * Prefer ASYMMETRIC encryption (OFFBOX_GPG_RECIPIENT): the box holds only the
#     recipient PUBLIC key, the private key lives off-box with the operator, so a
#     box compromise cannot decrypt past off-box copies. A symmetric passphrase
#     (OFFBOX_GPG_PASSPHRASE_FILE) is supported as a fallback.
#   * The destination must STILL be treated as secret (no plaintext, no shared
#     bucket) — defence in depth, not an excuse to use a public bucket.
#
# TRANSPORTS (auto-detected from whichever vars are set; OFFBOX_TRANSPORT forces)
#   ssh / rsync : second host over SSH      (OFFBOX_SSH_TARGET user@host:/path)
#   local       : a mounted second volume   (OFFBOX_LOCAL_DIR /mnt/offbox/...)
#   rclone      : any rclone remote         (OFFBOX_RCLONE_REMOTE remote:path)
#   s3          : S3-compatible object store (OFFBOX_S3_URI s3://bucket/prefix)
#
# CONFIG lives in a PRIVATE env file (NOT in git), default
# /etc/vault-keystore-offbox.env — seeded commented-out by box-scripts/install.sh.
# Until BOTH an encryption method AND a destination are configured the job is a
# safe log-only no-op (exit 0), so installing it on a not-yet-provisioned box is
# harmless and never pages.
#
# ALERTING mirrors the other box watchers: edge-triggered + de-duped via a state
# file, pages ntfy `a11oy-uptime-notify` on the healthy->fail edge and once on
# RECOVERED. Every run appends to the log + a status file so a broken notifier
# can never hide a failure. A failed off-box push when the job IS configured is
# an ALERT (the off-box copy is now stale); an unconfigured job never pages.
#
# Driven by vault-keystore-offbox-backup.timer (weekly by default). Installed at
# /usr/local/sbin/vault-keystore-offbox-backup. Versioned in repo box-scripts/.
# Companion restore: docs/operations/VAULT_PERSISTENT_RUNBOOK.md § 7.
#
# Exit codes: 0 success OR safe no-op (unconfigured / nothing to back up);
#             1 a configured push/encrypt failed (alerts).
set -uo pipefail

# ---- config (all overridable via env for testing) ---------------------------
ENV_FILE="${VAULT_OFFBOX_ENV_FILE:-/etc/vault-keystore-offbox.env}"
# Load the private config if present (never fatal if absent; allows pure-env runs)
if [[ -f "$ENV_FILE" ]]; then
  # shellcheck disable=SC1090
  set -a; . "$ENV_FILE"; set +a
fi

BACKUP_DIR="${VAULT_KEYSTORE_BACKUP_DIR:-/root/vault-keystore-backup}"
LATEST_LINK="${VAULT_KEYSTORE_LATEST:-$BACKUP_DIR/latest}"
# Optionally take a FRESH local snapshot first so the off-box copy is current.
# Soft: if the cluster/Vault is unreachable the backup script exits 3 and we fall
# back to shipping whatever 'latest' already points at.
RUN_LOCAL_BACKUP="${RUN_LOCAL_BACKUP:-1}"
LOCAL_BACKUP_SCRIPT="${LOCAL_BACKUP_SCRIPT:-/opt/szl/szl-uds-deployment/scripts/vault-keystore-backup.sh}"

OFFBOX_KEEP="${OFFBOX_KEEP:-14}"
OFFBOX_TRANSPORT="${OFFBOX_TRANSPORT:-}"   # auto-detect when empty

STATE_DIR="${STATE_DIR:-/var/lib/vault-keystore-offbox}"
STATE_FILE="${STATE_FILE:-$STATE_DIR/state}"        # OK | FAIL (for edge dedup)
STATUS_FILE="${STATUS_FILE:-$STATE_DIR/status.json}" # last-run observability
NOTIFY_CMD="${NOTIFY_CMD:-/usr/local/sbin/a11oy-uptime-notify}"
NOTIFY_TITLE="${NOTIFY_TITLE:-vault-keystore off-box backup}"

log() { echo "[vault-keystore-offbox] $*"; }

mkdir -p "$STATE_DIR" 2>/dev/null || true
chmod 700 "$STATE_DIR" 2>/dev/null || true

# Edge-triggered notifier. $1=new state (OK|FAIL), rest=message.
prev_state() { [[ -f "$STATE_FILE" ]] && cat "$STATE_FILE" 2>/dev/null || echo "INIT"; }
set_state()  { printf '%s\n' "$1" > "$STATE_FILE" 2>/dev/null || true; }
notify() {
  local newst="$1"; shift; local msg="$*"
  local prev; prev="$(prev_state)"
  set_state "$newst"
  # Only page on a state CHANGE (edge). INIT->OK is silent (first healthy run).
  if [[ "$newst" == "$prev" ]]; then return 0; fi
  if [[ "$newst" == "OK" && "$prev" == "INIT" ]]; then return 0; fi
  local prefix="ALERT"
  [[ "$newst" == "OK" ]] && prefix="RECOVERED"
  if [[ -x "$NOTIFY_CMD" ]]; then
    printf '%s: %s\n' "$prefix" "$msg" | NOTIFY_TITLE="$NOTIFY_TITLE" "$NOTIFY_CMD" || true
  else
    log "(notifier $NOTIFY_CMD not executable; would have paged) $prefix: $msg"
  fi
}

write_status() {
  # $1 result string, $2 detail
  local result="$1"; shift; local detail="$*"
  cat > "$STATUS_FILE" 2>/dev/null <<EOF || true
{
  "checked_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "result": "$result",
  "transport": "${OFFBOX_TRANSPORT:-}",
  "detail": "$(printf '%s' "$detail" | sed 's/"/\\"/g')"
}
EOF
  chmod 600 "$STATUS_FILE" 2>/dev/null || true
}

fail() {
  local msg="$*"
  log "ERROR: $msg"
  write_status "FAIL" "$msg"
  notify "FAIL" "$msg"
  exit 1
}

# ---- 0) Is the job configured? Encryption AND a destination are both required. -
have_encryption=0
if [[ -n "${OFFBOX_GPG_RECIPIENT:-}" ]]; then have_encryption=1; fi
if [[ -n "${OFFBOX_GPG_PASSPHRASE_FILE:-}" && -f "${OFFBOX_GPG_PASSPHRASE_FILE:-/nonexistent}" ]]; then have_encryption=1; fi

# Auto-detect transport from whichever destination var is set (first wins).
detect_transport() {
  [[ -n "$OFFBOX_TRANSPORT" ]] && { echo "$OFFBOX_TRANSPORT"; return; }
  if [[ -n "${OFFBOX_SSH_TARGET:-}" ]]; then echo "ssh"; return; fi
  if [[ -n "${OFFBOX_LOCAL_DIR:-}" ]]; then echo "local"; return; fi
  if [[ -n "${OFFBOX_RCLONE_REMOTE:-}" ]]; then echo "rclone"; return; fi
  if [[ -n "${OFFBOX_S3_URI:-}" ]]; then echo "s3"; return; fi
  echo ""
}
OFFBOX_TRANSPORT="$(detect_transport)"

if [[ "$have_encryption" != "1" || -z "$OFFBOX_TRANSPORT" ]]; then
  log "off-box backup NOT configured (need an encryption method + a destination in $ENV_FILE) — log-only no-op."
  write_status "SKIPPED_UNCONFIGURED" "set OFFBOX_GPG_RECIPIENT or OFFBOX_GPG_PASSPHRASE_FILE and a destination in $ENV_FILE"
  # Unconfigured is NOT a failure: do not page, do not touch the OK/FAIL edge state.
  exit 0
fi
command -v gpg >/dev/null || fail "gpg not found on PATH (required to encrypt the snapshot)"

# ---- 1) Optionally refresh the local snapshot, then resolve 'latest'. --------
if [[ "$RUN_LOCAL_BACKUP" == "1" && -x "$LOCAL_BACKUP_SCRIPT" ]]; then
  log "refreshing local snapshot via $LOCAL_BACKUP_SCRIPT (soft: exit 3 = cluster down, fall back to existing latest)"
  if "$LOCAL_BACKUP_SCRIPT" --backup-dir "$BACKUP_DIR" >/dev/null 2>&1; then
    log "fresh local snapshot taken."
  else
    rc=$?
    if [[ "$rc" == "3" ]]; then
      log "no reachable Vault to snapshot (rc=3) — shipping the most recent existing snapshot instead."
    else
      log "WARNING: local backup script exited $rc — shipping the most recent existing snapshot instead."
    fi
  fi
fi

if [[ ! -e "$LATEST_LINK" ]]; then
  fail "no local keystore snapshot found at $LATEST_LINK — run scripts/vault-keystore-backup.sh first"
fi
SNAP_DIR="$(readlink -f "$LATEST_LINK")"
[[ -d "$SNAP_DIR" ]] || fail "latest snapshot target '$SNAP_DIR' is not a directory"
# A usable snapshot must carry the barrier tar AND the unseal shares — without the
# shares the off-box copy cannot be decrypted on restore, which would be a silent
# false sense of safety.
[[ -s "$SNAP_DIR/vault-data.tar.gz" ]] || fail "snapshot $SNAP_DIR has no vault-data.tar.gz"
[[ -s "$SNAP_DIR/init.json" ]] || fail "snapshot $SNAP_DIR has no init.json (unseal shares) — refusing to ship an unrestorable backup"
SNAP_TS="$(basename "$SNAP_DIR")"
log "shipping snapshot $SNAP_TS from $SNAP_DIR"

# ---- 2) Package + encrypt in a root-only temp dir; shred the plaintext. ------
TMP="$(mktemp -d "${TMPDIR:-/tmp}/vault-offbox.XXXXXX")" || fail "mktemp failed"
chmod 700 "$TMP"
cleanup() {
  # Defence in depth: shred any plaintext tar, then remove the temp dir.
  [[ -f "$TMP/plain.tar.gz" ]] && shred -u "$TMP/plain.tar.gz" 2>/dev/null || true
  rm -rf "$TMP" 2>/dev/null || true
}
trap cleanup EXIT

PLAIN="$TMP/plain.tar.gz"
# Bundle the whole snapshot dir (barrier tar + init.json + pubkey.txt + meta.json)
# under a stable top-level name so restore is unambiguous.
tar czf "$PLAIN" -C "$BACKUP_DIR" "$SNAP_TS" || fail "failed to package snapshot $SNAP_TS"
[[ -s "$PLAIN" ]] || fail "packaged tar is empty"

ARTIFACT_BASE="vault-keystore-${SNAP_TS}.tar.gz.gpg"
CIPHER="$TMP/$ARTIFACT_BASE"

if [[ -n "${OFFBOX_GPG_RECIPIENT:-}" ]]; then
  log "encrypting (asymmetric) for recipient ${OFFBOX_GPG_RECIPIENT}"
  gpg --batch --yes --trust-model always \
      --recipient "$OFFBOX_GPG_RECIPIENT" \
      --output "$CIPHER" --encrypt "$PLAIN" \
    || fail "gpg asymmetric encryption failed for recipient ${OFFBOX_GPG_RECIPIENT}"
else
  log "encrypting (symmetric) with passphrase file ${OFFBOX_GPG_PASSPHRASE_FILE}"
  gpg --batch --yes \
      --pinentry-mode loopback \
      --passphrase-file "$OFFBOX_GPG_PASSPHRASE_FILE" \
      --cipher-algo AES256 \
      --output "$CIPHER" --symmetric "$PLAIN" \
    || fail "gpg symmetric encryption failed"
fi
[[ -s "$CIPHER" ]] || fail "produced an empty ciphertext"
# Structural sanity: it must be a real OpenPGP message (we can't decrypt an
# asymmetric blob here, but we can confirm it parses as PGP packets).
gpg --list-packets "$CIPHER" >/dev/null 2>&1 || fail "ciphertext does not parse as an OpenPGP message"
# Never let the plaintext leave: shred it as soon as the ciphertext exists.
shred -u "$PLAIN" 2>/dev/null || rm -f "$PLAIN"

CIPHER_SHA="$(sha256sum "$CIPHER" | awk '{print $1}')"
printf '%s  %s\n' "$CIPHER_SHA" "$ARTIFACT_BASE" > "$CIPHER.sha256"
log "ciphertext ready: $ARTIFACT_BASE ($(du -h "$CIPHER" | awk '{print $1}'), sha256 $CIPHER_SHA)"

# ---- 3) Ship to the off-box destination (+ checksum sidecar). ---------------
ship_ssh() {
  # OFFBOX_SSH_TARGET = user@host:/abs/path
  local key_opt=() ssh_opts=(${OFFBOX_SSH_OPTS:-})
  [[ -n "${OFFBOX_SSH_KEY:-}" ]] && key_opt=(-i "$OFFBOX_SSH_KEY")
  local hostpart="${OFFBOX_SSH_TARGET%%:*}"
  local pathpart="${OFFBOX_SSH_TARGET#*:}"
  ssh "${key_opt[@]}" -o BatchMode=yes -o StrictHostKeyChecking=accept-new "${ssh_opts[@]}" \
      "$hostpart" "mkdir -p '$pathpart' && chmod 700 '$pathpart'" \
    || return 1
  scp "${key_opt[@]}" -o BatchMode=yes -o StrictHostKeyChecking=accept-new "${ssh_opts[@]}" \
      "$CIPHER" "$CIPHER.sha256" "$OFFBOX_SSH_TARGET/" \
    || return 1
}
prune_ssh() {
  local key_opt=() ssh_opts=(${OFFBOX_SSH_OPTS:-})
  [[ -n "${OFFBOX_SSH_KEY:-}" ]] && key_opt=(-i "$OFFBOX_SSH_KEY")
  local hostpart="${OFFBOX_SSH_TARGET%%:*}"
  local pathpart="${OFFBOX_SSH_TARGET#*:}"
  ssh "${key_opt[@]}" -o BatchMode=yes -o StrictHostKeyChecking=accept-new "${ssh_opts[@]}" "$hostpart" \
    "ls -1t '$pathpart'/vault-keystore-*.tar.gz.gpg 2>/dev/null | tail -n +$((OFFBOX_KEEP+1)) | while read -r f; do rm -f \"\$f\" \"\$f.sha256\"; done" \
    || true
}

ship_local() {
  mkdir -p "$OFFBOX_LOCAL_DIR" || return 1
  chmod 700 "$OFFBOX_LOCAL_DIR" 2>/dev/null || true
  install -m 600 "$CIPHER" "$OFFBOX_LOCAL_DIR/$ARTIFACT_BASE" || return 1
  install -m 600 "$CIPHER.sha256" "$OFFBOX_LOCAL_DIR/$ARTIFACT_BASE.sha256" || return 1
}
prune_local() {
  ls -1t "$OFFBOX_LOCAL_DIR"/vault-keystore-*.tar.gz.gpg 2>/dev/null | tail -n +$((OFFBOX_KEEP+1)) \
    | while read -r f; do rm -f "$f" "$f.sha256"; done
}

ship_rclone() {
  command -v rclone >/dev/null || { log "rclone not installed"; return 1; }
  rclone copy "$CIPHER" "$OFFBOX_RCLONE_REMOTE/" || return 1
  rclone copy "$CIPHER.sha256" "$OFFBOX_RCLONE_REMOTE/" || return 1
}
prune_rclone() {
  command -v rclone >/dev/null || return 0
  # Keep the newest $OFFBOX_KEEP; rclone lsf sorted by modtime descending.
  rclone lsf --files-only --format tp "$OFFBOX_RCLONE_REMOTE/" 2>/dev/null \
    | grep 'vault-keystore-.*\.tar\.gz\.gpg$' | sort -r | tail -n +$((OFFBOX_KEEP+1)) \
    | sed 's/^[^;]*;//' \
    | while read -r f; do rclone delete "$OFFBOX_RCLONE_REMOTE/$f" 2>/dev/null || true; rclone delete "$OFFBOX_RCLONE_REMOTE/$f.sha256" 2>/dev/null || true; done
}

ship_s3() {
  command -v aws >/dev/null || { log "aws cli not installed"; return 1; }
  local ep=(); [[ -n "${OFFBOX_S3_ENDPOINT:-}" ]] && ep=(--endpoint-url "$OFFBOX_S3_ENDPOINT")
  aws "${ep[@]}" s3 cp "$CIPHER" "$OFFBOX_S3_URI/$ARTIFACT_BASE" --sse AES256 || return 1
  aws "${ep[@]}" s3 cp "$CIPHER.sha256" "$OFFBOX_S3_URI/$ARTIFACT_BASE.sha256" --sse AES256 || return 1
}
prune_s3() {
  command -v aws >/dev/null || return 0
  local ep=(); [[ -n "${OFFBOX_S3_ENDPOINT:-}" ]] && ep=(--endpoint-url "$OFFBOX_S3_ENDPOINT")
  # s3 ls returns "<date> <time> <size> <key>"; sort by key (ts-encoded) desc.
  aws "${ep[@]}" s3 ls "$OFFBOX_S3_URI/" 2>/dev/null | awk '{print $NF}' \
    | grep '^vault-keystore-.*\.tar\.gz\.gpg$' | sort -r | tail -n +$((OFFBOX_KEEP+1)) \
    | while read -r f; do aws "${ep[@]}" s3 rm "$OFFBOX_S3_URI/$f" 2>/dev/null || true; aws "${ep[@]}" s3 rm "$OFFBOX_S3_URI/$f.sha256" 2>/dev/null || true; done
}

case "$OFFBOX_TRANSPORT" in
  ssh|rsync) [[ -n "${OFFBOX_SSH_TARGET:-}" ]]   || fail "OFFBOX_TRANSPORT=ssh but OFFBOX_SSH_TARGET unset"
             ship_ssh    || fail "ssh/scp push to $OFFBOX_SSH_TARGET failed"; prune_ssh ;;
  local)     [[ -n "${OFFBOX_LOCAL_DIR:-}" ]]    || fail "OFFBOX_TRANSPORT=local but OFFBOX_LOCAL_DIR unset"
             ship_local  || fail "copy to $OFFBOX_LOCAL_DIR failed"; prune_local ;;
  rclone)    [[ -n "${OFFBOX_RCLONE_REMOTE:-}" ]]|| fail "OFFBOX_TRANSPORT=rclone but OFFBOX_RCLONE_REMOTE unset"
             ship_rclone || fail "rclone copy to $OFFBOX_RCLONE_REMOTE failed"; prune_rclone ;;
  s3)        [[ -n "${OFFBOX_S3_URI:-}" ]]       || fail "OFFBOX_TRANSPORT=s3 but OFFBOX_S3_URI unset"
             ship_s3     || fail "aws s3 cp to $OFFBOX_S3_URI failed"; prune_s3 ;;
  *)         fail "unknown OFFBOX_TRANSPORT='$OFFBOX_TRANSPORT' (use ssh|local|rclone|s3)" ;;
esac

# ---- 4) Success. -----------------------------------------------------------
DEST_DESC="$OFFBOX_TRANSPORT"
case "$OFFBOX_TRANSPORT" in
  ssh|rsync) DEST_DESC="ssh:$OFFBOX_SSH_TARGET" ;;
  local)     DEST_DESC="local:$OFFBOX_LOCAL_DIR" ;;
  rclone)    DEST_DESC="rclone:$OFFBOX_RCLONE_REMOTE" ;;
  s3)        DEST_DESC="s3:$OFFBOX_S3_URI" ;;
esac
log "off-box backup OK: $ARTIFACT_BASE -> $DEST_DESC (kept newest $OFFBOX_KEEP, sha256 $CIPHER_SHA)"
write_status "OK" "$ARTIFACT_BASE -> $DEST_DESC (sha256 $CIPHER_SHA)"
notify "OK" "off-box keystore backup restored to health: $ARTIFACT_BASE -> $DEST_DESC"
exit 0
