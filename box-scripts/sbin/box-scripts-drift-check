#!/usr/bin/env bash
#
# box-scripts-drift-check — catch the box's host-level helper scripts/units
# drifting away from their committed copies in szl-holdings/szl-uds-deployment on
# Stephen's box (167.233.50.75).
#
# WHY: scripts like a11oy-uptime-check, a11oy-uptime-notify and dns-drift-check
# are the source of truth and get edited IN PLACE under /usr/local/sbin (and
# their units under /etc/systemd/system). Those host paths live OUTSIDE any git
# checkout, so even though their canonical copies are committed under
# box-scripts/{sbin,systemd}/, the live versions can silently diverge again (the
# repo copies lagged until they were last hand-pulled). The BOX-SYNC rule only
# guards the git working tree, not these host files. This watcher byte-compares
# each live file against its committed box-scripts/ copy and alerts on drift, so
# the repo copy stays the real source of truth.
#
# By DEFAULT it only REPORTS — it does NOT auto-reinstall. Re-syncing the host
# file with the repo (or committing the live edit back into box-scripts/) is a
# human/agent call (run box-scripts/install.sh to push repo->host, or copy
# host->repo + commit). For the case where the COMMITTED copy is the desired
# source of truth and a stray host edit should simply be reverted, an OPT-IN
# self-heal mode (SELF_HEAL=1, default OFF) re-installs the drifted file from its
# box-scripts/ copy on the drift edge — see "SELF-HEAL" below. This mirrors the
# sibling dns-drift watcher's opt-in re-apply, but it is OFF by default here
# because a host edit may legitimately be a hot-fix that should be back-ported to
# the repo, not clobbered.
#
# WHAT IT COMPARES (self-maintaining — derived, NOT a fixed list):
#   The watch set is DERIVED from the `install -m ... "$here/sbin/X" ...` /
#   `"$here/systemd/Y" ...` mapping in box-scripts/install.sh, so every helper
#   install.sh actually installs is watched automatically — adding a new helper
#   to install.sh covers it here with zero edits to this script. Each derived
#   name is compared:
#     /usr/local/sbin/<name>        vs $REPO/box-scripts/sbin/<name>      (scripts)
#     /etc/systemd/system/<name>    vs $REPO/box-scripts/systemd/<name>   (units)
#   Override the derived set explicitly with WATCH_SBIN / WATCH_UNITS (used by
#   the isolated test recipe), drop entries that legitimately have no committed
#   copy with WATCH_EXCLUDE, and point INSTALL_SH elsewhere if needed. If
#   install.sh is unreadable/yields nothing the original static set is used as a
#   fallback so the guard never silently watches nothing.
# Per file the status is one of:
#   MATCH        live == committed (good)
#   DRIFT        both exist but differ (live edited, or repo lagging)
#   LIVE-MISSING committed copy exists but the host file is gone (not installed)
#   REPO-MISSING host file exists but the committed copy is gone (lost source)
#
# ALERTING
#   Edge-triggered: alerts ONCE on the healthy->drift edge, de-duped via an md5
#   signature of the current drift set, so a persisting drift does not spam. A
#   return to all-MATCH logs/pushes RECOVERED and clears the signature so a fresh
#   drift re-alerts. Mirrors the dns-drift / repo-drift / a11oy-uptime monitors.
#
#   The path is always a clearly-named LOG + a machine-readable STATUS FILE. On
#   top of that it sends a REAL push on the drift edge / RECOVERED via the SAME
#   notifier the a11oy-uptime + dns-drift monitors use
#   (/usr/local/sbin/a11oy-uptime-notify -> ntfy / Telegram / Slack-Discord
#   webhook), wired through NOTIFY_CMD in the service unit. SMS/email is NOT used
#   (no Gmail/nodemailer transport on this box; outbound TCP 465 is firewalled —
#   see sms-alerts-on-hetzner). NOTIFY_CMD reads the alert on stdin and is
#   fail-soft. Because it only fires on the EDGE and on RECOVERED it respects the
#   standing "recurring alerts = the owner only" policy by construction.
#
# SELF-HEAL (opt-in, OFF by default; scope it narrow when you turn it on)
#   With SELF_HEAL=1 the watcher re-installs each drifted host file from its
#   committed box-scripts/ copy (install -m, scripts 0755 / units 0644) and, if
#   any unit was re-installed, runs `systemctl daemon-reload`. It then pushes a
#   REPAIRED notification (distinct from the RECOVERED that fires when the drift
#   simply clears on its own). A DRIFT whose committed source is GONE
#   (REPO-MISSING / BOTH-MISSING) cannot be restored and is reported as
#   un-healable. A drift that is still present after a heal (e.g. an un-healable
#   REPO-MISSING, or install keeps failing) is retried at most once every
#   HEAL_RETRY_SECS so it never loops.
#
#   ONE-CYCLE GRACE (HEAL_GRACE=1, the default when self-heal is on): on the
#   FIRST healthy->drift edge the watcher only ALERTS — it does NOT clobber the
#   host file yet. It re-installs the committed copy only on a SUBSEQUENT run if
#   the same drift is still present. This deliberately leaves a window (one timer
#   cycle, ~15 min) to back-port a genuine local hot-fix into the repo before the
#   committed copy overwrites it — the documented "back-port vs clobber" hazard.
#   The DRIFT edge alert spells this out ("NOT auto-repairing on this first
#   drift…"). Set HEAL_GRACE=0 to restore the original heal-on-the-first-edge
#   behaviour. To shrink the blast radius further, scope WHICH files self-heal
#   touches with WATCH_SBIN / WATCH_UNITS (see install.sh) rather than healing
#   the whole watched set.
#   With SELF_HEAL=0 (the default) the detection + alert + edge/de-dup path is
#   exactly the original report-only behaviour.
#
# Idempotent and safe to run on a short timer. Repo-absent = clean no-op.
set -uo pipefail

# ---- config (overridable via env for testing) -------------------------------
REPO="${REPO:-/opt/szl/szl-uds-deployment}"
BOX_SCRIPTS="${BOX_SCRIPTS:-$REPO/box-scripts}"
SBIN_DIR="${SBIN_DIR:-/usr/local/sbin}"
UNIT_DIR="${UNIT_DIR:-/etc/systemd/system}"

# Watched host-level helper scripts/units. By DEFAULT the watch set is DERIVED
# from the install -m mapping in box-scripts/install.sh (see derive_install_set
# + resolve_watch_set below), so the guard self-maintains as box-scripts/ grows.
# Set WATCH_SBIN / WATCH_UNITS explicitly (space-separated basenames) to OVERRIDE
# derivation (used by the isolated test recipe / a manual narrowing). They are
# left UNSET here on purpose so "unset" means "derive"; an explicit empty string
# also overrides (watch nothing of that kind).
INSTALL_SH="${INSTALL_SH:-$BOX_SCRIPTS/install.sh}"
# Drop basenames that legitimately have no committed copy / should not be watched
# (space-separated, matches scripts and units alike).
WATCH_EXCLUDE="${WATCH_EXCLUDE:-}"
# Static fallback used ONLY when derivation yields nothing (install.sh missing /
# unreadable) so the guard never silently watches nothing. Kept comprehensive —
# it mirrors every self-heal / alert helper box-scripts/install.sh installs (the
# cluster headroom guards szl-core-rightsize / istiod-fit-strategy, the receipt
# watchers receipt-chain-watch / receipt-flood-watch, the scratch-namespace
# guards szl-ns-scratch-watch / *-stale-watch, the signing-health guard
# szl-signing-health-check, the receipts-orphan guard, the uptime/DNS watchers,
# the alert relay, and this guard itself) so that even in the degraded
# install.sh-unreadable case ALL self-heal scripts stay watched, not just the
# uptime/DNS trio. Derivation (above) remains the PRIMARY, self-maintaining path
# for normal operation; this list only has to be touched if install.sh is
# unreadable AND a new helper must be covered in that degraded mode.
FALLBACK_SBIN="a11oy-contracting-tool-watch a11oy-mode a11oy-port-guard a11oy-readiness-watch a11oy-serverlb-deconflict \
a11oy-signing-key-watch a11oy-uptime-check a11oy-uptime-notify \
authelia-rotate-demo box-scripts-drift-check bundle-digest-recut bundle-digest-watch dns-drift-check \
eval-arena-trend-validate eval-arena-trend-watch \
istiod-fit-strategy receipt-chain-watch receipt-flood-watch receipt-throttle-watch \
szl-alert-relay szl-alert-relay-watch szl-box-sync-conflict-watch szl-core-rightsize szl-ns-scratch \
szl-image-stale-watch szl-ns-scratch-stale-watch szl-ns-scratch-watch szl-receipt-checkpoint \
szl-receipts-cold-archive-audit szl-receipts-cold-offsite szl-receipts-cold-offsite-restore-drill szl-receipts-orphan-watch szl-receipts-retention szl-receipts-retention-watch \
szl-signing-health-check vault-auto-unseal vault-keystore-offbox-backup"
FALLBACK_UNITS="a11oy-coexist.service a11oy-contracting-tool-watch.service a11oy-contracting-tool-watch.timer \
a11oy-port-guard.service a11oy-port-guard.timer a11oy-readiness-watch.service a11oy-readiness-watch.timer a11oy-signing-key-watch.service \
a11oy-signing-key-watch.timer a11oy-uptime-check.service a11oy-uptime-check.timer \
authelia-rotate-demo.service authelia-rotate-demo.timer box-scripts-drift-check.service \
box-scripts-drift-check.timer bundle-digest-recut.service bundle-digest-recut.timer \
bundle-digest-watch.service bundle-digest-watch.timer dns-drift-check.service dns-drift-check.timer \
eval-arena-trend-watch.service eval-arena-trend-watch.timer \
istiod-fit-strategy.service istiod-fit-strategy.timer receipt-chain-watch.service \
receipt-chain-watch@.service receipt-chain-watch.timer receipt-chain-watch@.timer \
receipt-flood-watch.service receipt-flood-watch@.service receipt-flood-watch.timer \
receipt-flood-watch@.timer receipt-throttle-watch.service receipt-throttle-watch@.service \
receipt-throttle-watch.timer receipt-throttle-watch@.timer szl-alert-relay.service \
szl-alert-relay-watch.service szl-alert-relay-watch.timer szl-core-rightsize.service \
szl-box-sync-conflict-watch.service szl-box-sync-conflict-watch.timer \
szl-core-rightsize.timer szl-image-stale-watch.service szl-image-stale-watch.timer szl-ns-scratch-stale-watch.service szl-ns-scratch-stale-watch.timer \
szl-ns-scratch-watch.service szl-ns-scratch-watch.timer szl-receipt-checkpoint.service \
szl-receipt-checkpoint.timer szl-receipts-cold-archive-audit.service szl-receipts-cold-archive-audit.timer szl-receipts-cold-offsite.service \
szl-receipts-cold-offsite.timer szl-receipts-cold-offsite-restore-drill.service szl-receipts-cold-offsite-restore-drill.timer szl-receipts-orphan-watch.service \
szl-receipts-orphan-watch.timer szl-receipts-retention.service \
szl-receipts-retention.timer szl-receipts-retention-watch.service szl-receipts-retention-watch.timer szl-signing-health-check.service \
szl-signing-health-check.timer vault-auto-unseal.service vault-auto-unseal.timer \
vault-keystore-offbox-backup.service vault-keystore-offbox-backup.timer"

STATE_DIR="${STATE_DIR:-/var/lib/box-scripts-drift}"
LOG_DIR="${LOG_DIR:-/var/log/box-scripts-drift}"
LOG="${LOG:-$LOG_DIR/box-scripts-drift.log}"
STATUS="${STATUS:-$STATE_DIR/status.json}"
SIG_FILE="${SIG_FILE:-$STATE_DIR/problem.sig}"
NOTIFY_CMD="${NOTIFY_CMD:-}"          # optional external notifier (stdin = message)
ALERT_PREFIX="${ALERT_PREFIX:-}"      # e.g. "[TEST-ignore] " to test without alarming

# ---- self-heal config (opt-in, OFF by default) ------------------------------
# When SELF_HEAL=1 the watcher re-installs each drifted host file from its
# committed box-scripts/ copy on the drift EDGE (and daemon-reloads if a unit
# changed), instead of only paging a human. OFF by default because a host edit
# may be a deliberate hot-fix that should be back-ported to the repo rather than
# clobbered. INSTALL_CMD / DAEMON_RELOAD_CMD are overridable for the isolated
# test recipe (see box-scripts-drift-check.README.md).
SELF_HEAL="${SELF_HEAL:-0}"
# HEAL_GRACE (default ON when self-heal is on): on the FIRST drift edge only
# ALERT, do not restore — heal on the NEXT run if the drift persists, leaving a
# window to back-port a genuine local hot-fix first. HEAL_GRACE=0 restores the
# original heal-on-the-first-edge behaviour.
HEAL_GRACE="${HEAL_GRACE:-1}"
INSTALL_CMD="${INSTALL_CMD:-install}"
DAEMON_RELOAD_CMD="${DAEMON_RELOAD_CMD:-systemctl daemon-reload}"
HEAL_TS_FILE="${HEAL_TS_FILE:-$STATE_DIR/heal-last.ts}"
HEAL_RESULT_FILE="${HEAL_RESULT_FILE:-$STATE_DIR/heal-last.txt}"
HEAL_RETRY_SECS="${HEAL_RETRY_SECS:-3600}"   # min seconds between heals for a persisting drift

mkdir -p "$STATE_DIR" "$LOG_DIR" 2>/dev/null

now_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)
log() { printf '%s %s\n' "$now_iso" "$*" >>"$LOG"; }

# push(): fire the external notifier (stdin = message). Fail-soft — a missing or
# broken notifier never hides the edge, which is always recorded in the log too.
push() {
  [ -z "$NOTIFY_CMD" ] && return 0
  printf '%s%s\n' "$ALERT_PREFIX" "$1" | $NOTIFY_CMD >>"$LOG" 2>&1 \
    || log "WARN notifier '$NOTIFY_CMD' failed"
}

json_escape() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }

# compare_one LIVE REPO -> echoes status (MATCH|DRIFT|LIVE-MISSING|REPO-MISSING)
compare_one() {
  local live="$1" repo="$2"
  if [ ! -e "$repo" ] && [ ! -e "$live" ]; then
    echo "BOTH-MISSING"; return
  fi
  if [ ! -e "$live" ]; then echo "LIVE-MISSING"; return; fi
  if [ ! -e "$repo" ]; then echo "REPO-MISSING"; return; fi
  if cmp -s "$live" "$repo"; then echo "MATCH"; else echo "DRIFT"; fi
}

# derive_install_set KIND -> echo newline-separated basenames pulled from the
# `install -m ... "$here/<KIND>/NAME" DEST` mapping in $INSTALL_SH. KIND is
# "sbin" or "systemd". We classify by the install SOURCE ("$here/sbin/..." /
# "$here/systemd/...") and watch the DEST basename (source basename == dest
# basename in install.sh), so installs into other trees (e.g. /etc/nginx) and
# `install -d` directory lines are ignored. De-duplicated, order preserved.
derive_install_set() {
  local kind="$1"
  [ -r "$INSTALL_SH" ] || return 0
  # grep -F: the literal `"$here/<kind>/` (the `$` is a literal char in the file).
  grep -F "\"\$here/$kind/" "$INSTALL_SH" 2>/dev/null \
    | grep -E '(^|[[:space:]])install([[:space:]]|$)' \
    | awk '{print $NF}' \
    | sed -E 's#.*/##' \
    | awk 'NF && !seen[$0]++'
}

# filter_excluded LIST... -> echo the space/newline-separated LIST with any
# basename present in $WATCH_EXCLUDE removed.
filter_excluded() {
  local name out=""
  for name in "$@"; do
    case " $WATCH_EXCLUDE " in
      *" $name "*) continue ;;
    esac
    out="$out $name"
  done
  printf '%s' "${out# }"
}

# ---- repo present? ----------------------------------------------------------
if [ ! -d "$REPO/.git" ] || [ ! -d "$BOX_SCRIPTS" ]; then
  log "STATE repo/box-scripts absent ($BOX_SCRIPTS) — no-op"
  {
    printf '{\n'
    printf '  "checked_at": "%s",\n' "$now_iso"
    printf '  "repo": "%s",\n' "$(json_escape "$REPO")"
    printf '  "overall": "ABSENT",\n'
    printf '  "drift_count": 0,\n'
    printf '  "alerting": false,\n'
    printf '  "files": []\n'
    printf '}\n'
  } >"$STATUS.tmp" && mv "$STATUS.tmp" "$STATUS"
  exit 0
fi

# ---- resolve the watch set --------------------------------------------------
# Default = DERIVE from install.sh's install -m mapping; an explicit WATCH_SBIN /
# WATCH_UNITS (even empty) overrides. Fall back to the static set only if
# derivation produced nothing. WATCH_EXCLUDE drops un-watchable basenames.
if [ -z "${WATCH_SBIN+set}" ]; then
  WATCH_SBIN="$(derive_install_set sbin)"
  [ -n "$WATCH_SBIN" ] || { WATCH_SBIN="$FALLBACK_SBIN"; log "WARN derived sbin watch set empty — using static fallback (INSTALL_SH=$INSTALL_SH)"; }
fi
if [ -z "${WATCH_UNITS+set}" ]; then
  WATCH_UNITS="$(derive_install_set systemd)"
  [ -n "$WATCH_UNITS" ] || { WATCH_UNITS="$FALLBACK_UNITS"; log "WARN derived unit watch set empty — using static fallback (INSTALL_SH=$INSTALL_SH)"; }
fi
WATCH_SBIN="$(filter_excluded $WATCH_SBIN)"
WATCH_UNITS="$(filter_excluded $WATCH_UNITS)"

# ---- walk the watch set -----------------------------------------------------
problems=()         # human-readable "name: STATUS" for each drifted file
files_json=()       # per-file json objects for status.json
heal_targets=()     # "kind|name|live|repo|status" for each drifted file (self-heal)

add_file_json() {   # name kind live repo status
  files_json+=("$(printf '{ "name": "%s", "kind": "%s", "live": "%s", "repo": "%s", "status": "%s" }' \
    "$(json_escape "$1")" "$2" "$(json_escape "$3")" "$(json_escape "$4")" "$5")")
}

check_set() {       # kind live_dir repo_dir names...
  local kind="$1" live_dir="$2" repo_dir="$3"; shift 3
  local name live repo st
  for name in "$@"; do
    live="$live_dir/$name"
    repo="$repo_dir/$name"
    st=$(compare_one "$live" "$repo")
    add_file_json "$name" "$kind" "$live" "$repo" "$st"
    if [ "$st" != "MATCH" ]; then
      problems+=("$kind $name: $st")
      heal_targets+=("$kind|$name|$live|$repo|$st")
    fi
  done
}

check_set "script" "$SBIN_DIR" "$BOX_SCRIPTS/sbin"    $WATCH_SBIN
check_set "unit"   "$UNIT_DIR" "$BOX_SCRIPTS/systemd" $WATCH_UNITS

drift_count=${#problems[@]}
overall="OK"; [ "$drift_count" -gt 0 ] && overall="DRIFT"

# ---- write the status file (always) ----------------------------------------
{
  printf '{\n'
  printf '  "checked_at": "%s",\n' "$now_iso"
  printf '  "repo": "%s",\n' "$(json_escape "$REPO")"
  printf '  "box_scripts": "%s",\n' "$(json_escape "$BOX_SCRIPTS")"
  printf '  "overall": "%s",\n' "$overall"
  printf '  "drift_count": %s,\n' "$drift_count"
  printf '  "alerting": %s,\n' "$( [ "$drift_count" -gt 0 ] && echo true || echo false )"
  printf '  "self_heal": { "enabled": %s, "grace": %s, "last_result": "%s" },\n' \
    "$( [ "$SELF_HEAL" = "1" ] && echo true || echo false )" \
    "$( [ "${HEAL_GRACE:-1}" = "1" ] && echo true || echo false )" \
    "$( [ -r "$HEAL_RESULT_FILE" ] && tr -d '\n' <"$HEAL_RESULT_FILE" | sed 's/"/\\"/g' || echo none )"
  printf '  "files": [\n'
  i=0
  for obj in "${files_json[@]}"; do
    i=$(( i + 1 ))
    if [ "$i" -lt "${#files_json[@]}" ]; then
      printf '    %s,\n' "$obj"
    else
      printf '    %s\n' "$obj"
    fi
  done
  printf '  ]\n'
  printf '}\n'
} >"$STATUS.tmp" && mv "$STATUS.tmp" "$STATUS"

# ---- self-heal helpers ------------------------------------------------------
# heal_due(): true when we should (re)attempt a re-install.
#   * With the one-cycle grace (HEAL_GRACE=1, default) a brand-new drift edge is
#     NOT healed — only alerted — so a genuine local hot-fix can be back-ported
#     before the committed copy clobbers it. The drift is healed on the NEXT run
#     if it is still present (is_new_edge=0). HEAL_GRACE=0 heals on the first
#     edge (the original behaviour).
#   * For a drift still present after a previous heal it only re-tries once
#     HEAL_RETRY_SECS has elapsed so it never loops (e.g. an un-healable
#     REPO-MISSING, or install repeatedly failing).
heal_due() {
  [ "$SELF_HEAL" = "1" ] || return 1
  if [ "${is_new_edge:-0}" = "1" ]; then
    # First drift edge: defer one cycle unless grace is explicitly off.
    [ "${HEAL_GRACE:-1}" = "1" ] && return 1
    return 0
  fi
  local last now
  last=$(cat "$HEAL_TS_FILE" 2>/dev/null || echo 0)
  case "$last" in (*[!0-9]*|"") last=0 ;; esac
  now=$(date -u +%s)
  [ $(( now - last )) -ge "$HEAL_RETRY_SECS" ]
}

# attempt_heal(): re-install each drifted file from its committed box-scripts/
# copy. Scripts -> 0755, units -> 0644; daemon-reload once if any unit changed.
# REPO-MISSING / BOTH-MISSING have no source to restore from (un-healable).
# Fail-soft: a failed install is logged/pushed but never aborts the watcher.
attempt_heal() {
  local entry kind name live repo st mode any_unit=0
  local healed=() failed=() skipped=()
  date -u +%s >"$HEAL_TS_FILE"
  for entry in "${heal_targets[@]}"; do
    IFS='|' read -r kind name live repo st <<<"$entry"
    case "$st" in
      DRIFT|LIVE-MISSING)
        mode=755; [ "$kind" = "unit" ] && mode=644
        if $INSTALL_CMD -m "$mode" "$repo" "$live" >>"$LOG" 2>&1; then
          healed+=("$kind $name")
          [ "$kind" = "unit" ] && any_unit=1
        else
          failed+=("$kind $name")
        fi
        ;;
      *)  # REPO-MISSING / BOTH-MISSING — no committed source to restore from
        skipped+=("$kind $name ($st)")
        ;;
    esac
  done

  if [ "$any_unit" = "1" ]; then
    if $DAEMON_RELOAD_CMD >>"$LOG" 2>&1; then
      log "SELF-HEAL daemon-reload OK (a watched unit was re-installed)"
    else
      log "WARN SELF-HEAL daemon-reload failed"
    fi
  fi

  local rc=0 summary=""
  if [ "${#healed[@]}" -gt 0 ]; then
    summary="re-installed ${#healed[@]} committed copy/copies onto the host: $(printf '%s, ' "${healed[@]}")"
    summary="${summary%, }"
    [ "$any_unit" = "1" ] && summary="$summary; ran daemon-reload"
  fi
  if [ "${#failed[@]}" -gt 0 ]; then
    rc=1
    summary="${summary:+$summary; }FAILED to re-install: $(printf '%s, ' "${failed[@]}")"
    summary="${summary%, }"
  fi
  if [ "${#skipped[@]}" -gt 0 ]; then
    summary="${summary:+$summary; }un-healable (no committed source): $(printf '%s, ' "${skipped[@]}")"
    summary="${summary%, }"
  fi
  [ -z "$summary" ] && summary="nothing to re-install"

  if [ "${#healed[@]}" -gt 0 ] && [ "${#failed[@]}" -eq 0 ]; then
    log "REPAIRED $summary"
    push "box-scripts-drift REPAIRED: $summary"
  else
    log "REPAIR-INCOMPLETE $summary"
    push "box-scripts-drift REPAIR could not fully restore: $summary"
  fi
  printf '%s %s\n' "$now_iso" "$summary" >"$HEAL_RESULT_FILE"
  return "$rc"
}

# ---- transition de-dup + alert ---------------------------------------------
prev_sig=""; [ -r "$SIG_FILE" ] && prev_sig=$(cat "$SIG_FILE" 2>/dev/null)

if [ "$drift_count" -eq 0 ]; then
  if [ -n "$prev_sig" ]; then
    rec="all watched box-scripts host files match their committed box-scripts/ copies again"
    log "RECOVERED $rec"
    push "box-scripts-drift RECOVERED: $rec"
    rm -f "$SIG_FILE" "$HEAL_TS_FILE"
  fi
  log "STATE overall=OK drift=0 (checked $(( $(printf '%s\n' $WATCH_SBIN | grep -c .) + $(printf '%s\n' $WATCH_UNITS | grep -c .) )) files)"
  exit 0
fi

problem_text=$(printf '%s; ' "${problems[@]}"); problem_text="${problem_text%; }"
cur_sig=$(printf '%s\n' "${problems[@]}" | sort | md5sum | awk '{print $1}')

is_new_edge=0
if [ "$cur_sig" = "$prev_sig" ]; then
  log "(persisting) DRIFT $drift_count file(s): $problem_text"
else
  is_new_edge=1
  if [ "$SELF_HEAL" = "1" ] && [ "${HEAL_GRACE:-1}" = "1" ]; then
    body="$drift_count box-scripts host file(s) DRIFTED from the committed box-scripts/ copies on $REPO:
$(printf '    %s\n' "${problems[@]}")
Self-heal ON (one-cycle grace): NOT auto-repairing on this first drift. If the live edit is intended, back-port it now (copy host->repo + commit); otherwise the committed copy will be re-installed on the next check."
  elif [ "$SELF_HEAL" = "1" ]; then
    body="$drift_count box-scripts host file(s) DRIFTED from the committed box-scripts/ copies on $REPO:
$(printf '    %s\n' "${problems[@]}")
Self-heal ON — auto-repairing now (re-installing the committed copies)..."
  else
    body="$drift_count box-scripts host file(s) DRIFTED from the committed box-scripts/ copies on $REPO:
$(printf '    %s\n' "${problems[@]}")
Reconcile: copy host->repo + commit if the live edit is intended, or re-run box-scripts/install.sh to push repo->host."
  fi
  log "ALERT $body"
  push "box-scripts-drift DRIFT: $body"
  printf '%s' "$cur_sig" >"$SIG_FILE"
fi

# self-heal (opt-in): re-install the drifted files from their committed copies.
if heal_due; then
  attempt_heal || true
fi

log "STATE overall=DRIFT drift=$drift_count self_heal=$( [ "$SELF_HEAL" = "1" ] && echo on || echo off ) grace=$( [ "${HEAL_GRACE:-1}" = "1" ] && echo on || echo off )"
exit 0
