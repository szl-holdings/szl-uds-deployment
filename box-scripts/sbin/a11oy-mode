#!/usr/bin/env bash
#
# a11oy-mode — manage how this single box serves ports 80/443.
#
# This box runs BOTH the public a-11-oy.com site (nginx + a11oy/killinchu
# containers) AND the UDS k3d demo cluster (uds-szl-demo, Task #103). They
# used to be mutually exclusive on 80/443; they now COEXIST: nginx owns host
# 80/443, and the k3d serverlb is kept off 80/443 (it still publishes the
# kube-API + 8443), so the cluster keeps running and is reached via
# `kubectl port-forward`.
#
# Usage:
#   a11oy-mode coexist  Make BOTH live: cluster running + nginx on 80/443.
#   a11oy-mode ensure   Boot-safe: ensure nginx is up on 80/443; deconflict
#                       the serverlb if it grabbed them. (Does NOT start the
#                       cluster — that stays on-demand.)
#   a11oy-mode public   Public site only (leaves cluster as-is, frees 80/443).
#   a11oy-mode status   Read-only: show what is currently serving.
set -uo pipefail

CL=uds-szl-demo
DECONFLICT=/usr/local/sbin/a11oy-serverlb-deconflict
HOSTS=("a-11-oy.com" "killinchu.a-11-oy.com" "elite.a-11-oy.com")

log()  { printf '\033[1;36m[a11oy-mode]\033[0m %s\n' "$*"; }
ok()   { printf '\033[1;32m[ ok ]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[warn]\033[0m %s\n' "$*"; }
err()  { printf '\033[1;31m[fail]\033[0m %s\n' "$*" >&2; }

require_root() {
  [ "$(id -u)" -eq 0 ] || { err "must run as root (sudo a11oy-mode $*)"; exit 1; }
}
nginx_active()    { systemctl is-active --quiet nginx; }
cluster_running() { k3d cluster list "$CL" --no-headers 2>/dev/null | awk '{print $2}' | grep -qE '^[1-9][0-9]*/'; }

verify_public() {
  local failed=0 h code
  for h in "${HOSTS[@]}"; do
    code=$(curl -s -o /dev/null -w '%{http_code}' --max-time 10 -H "Host: $h" http://127.0.0.1/ || echo 000)
    case "$code" in 200|301|308) ok "$h -> $code" ;; *) err "$h -> $code"; failed=1 ;; esac
  done
  return $failed
}

cmd_ensure() {
  require_root ensure
  log "Ensuring nginx owns 80/443 (deconflicting serverlb if needed)..."
  [ -x "$DECONFLICT" ] && "$DECONFLICT"
  systemctl enable nginx >/dev/null 2>&1
  if ! nginx_active; then systemctl start nginx || { err "nginx failed to start"; exit 1; }; fi
  verify_public || { err "a vhost did not answer"; exit 1; }
  ok "public site is live on 80/443."
}

cmd_coexist() {
  require_root coexist
  log "Bringing BOTH the cluster and the public site up..."
  if ! cluster_running; then
    log "cluster '$CL' down -> starting it (nginx stays up; serverlb is durably off 80/443)..."
    k3d cluster start "$CL" || { err "k3d cluster start failed"; exit 1; }
  fi
  # The serverlb no longer publishes host 80/443 (clean container, preserved by
  # k3d cluster start; fresh clusters are created port-guarded) so the deconflict
  # below is now just a SAFETY NET — a no-op unless something regrabbed 80/443.
  log "safety-net: ensuring serverlb is off 80/443 (no-op if already clear)..."
  [ -x "$DECONFLICT" ] && "$DECONFLICT"
  systemctl enable nginx >/dev/null 2>&1
  nginx_active || systemctl start nginx || { err "nginx failed to start"; exit 1; }
  verify_public || { err "a vhost did not answer"; exit 1; }
  cluster_running && ok "cluster '$CL' running" || warn "cluster '$CL' not running"
  # Pin UDS-core HA components to single-replica so szl-receipts/admin gateway/
  # operator watcher fit this 2-vCPU node right away (no manual kubectl scale).
  [ -x /usr/local/sbin/szl-core-rightsize ] && /usr/local/sbin/szl-core-rightsize || true
  ok "COEXISTENCE live: nginx on 80/443 + UDS cluster running."
}

cmd_public() {
  require_root public
  log "Serving the public site only (freeing 80/443, leaving cluster as-is)..."
  [ -x "$DECONFLICT" ] && "$DECONFLICT"
  systemctl enable nginx >/dev/null 2>&1
  systemctl restart nginx || { err "nginx failed to start"; exit 1; }
  verify_public && ok "public site live." || { err "a vhost did not answer"; exit 1; }
}

cmd_status() {
  nginx_active && ok "nginx ACTIVE (public site on 80/443)" || warn "nginx stopped"
  cluster_running && ok "k3d cluster '$CL' RUNNING" || warn "k3d cluster '$CL' stopped"
  if docker inspect k3d-uds-szl-demo-serverlb >/dev/null 2>&1; then
    local pb; pb=$(docker inspect k3d-uds-szl-demo-serverlb --format '{{json .HostConfig.PortBindings}}' 2>/dev/null)
    printf '%s' "$pb" | grep -qE '"(80|443)/tcp"' \
      && warn "serverlb still publishes host 80/443 (run: a11oy-mode ensure)" \
      || ok "serverlb is clear of host 80/443"
  fi
}

case "${1:-}" in
  coexist) cmd_coexist ;;
  ensure)  cmd_ensure ;;
  public)  cmd_public ;;
  status)  cmd_status ;;
  ""|-h|--help|help)
    sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//' ;;
  *) err "unknown subcommand: $1"; exit 2 ;;
esac
