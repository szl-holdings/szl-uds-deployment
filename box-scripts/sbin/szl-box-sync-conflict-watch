#!/usr/bin/env bash
#
# szl-box-sync-conflict-watch — alert when the box auto-sync could NOT cleanly
# reconcile the shared szl-uds-deployment tree with origin/main and has left it
# in a silent, half-merged state on Stephen's box (167.233.50.75).
#
# BACKGROUND
# szl-box-sync-pull.timer fast-forwards /opt/szl/szl-uds-deployment onto
# origin/main every ~15 min. The reconcile (szl-box-sync's reset_in_line) is
# NON-DESTRUCTIVE by design: when a sibling has uncommitted TRACKED edits that
# ALSO changed on origin, the run still fast-forwards but the stash pop conflicts,
# leaving the tree with:
#   * UU (unmerged) paths in the working tree, AND
#   * the sibling's edit preserved in a `szl-box-sync autostash <ts>` stash.
# No work is lost, but the state is SILENT — nobody is told the tree is now
# conflict-marked and a sibling's work is sitting in a stash. Over many 15-min
# cycles the stashes accumulate and the working tree stays confusingly
# half-merged. This watcher surfaces exactly that.
#
# WHAT IT CHECKS (read-only, on the live box tree):
#   1. unmerged (UU) paths            — `git ls-files -u`
#   2. retained szl-box-sync stashes  — `git stash list` lines matching the
#                                        autostash label szl-box-sync writes
#                                        (STASH_MATCH, default "szl-box-sync
#                                        autostash"), so unrelated MANUAL stashes
#                                        never trip the alarm.
#
# IT NEVER MUTATES THE TREE. It does not pop, drop, clear, reset, checkout,
# merge, or rm anything — it only reports. Resolving the conflict / clearing the
# stash is a human (or a dedicated task) decision; this watcher just makes the
# silent state loud.
#
# ALERTING
#   Alerts ONLY on the healthy->problem edge (transition de-dup via an md5
#   signature of the current problem set), so a persisting conflict does not
#   spam. A return to a clean tree logs RECOVERED and clears the signature so a
#   fresh conflict re-alerts. This mirrors the dns-drift / a11oy-uptime monitors.
#
#   The notification path is always: a clearly-named LOG + a machine-readable
#   STATUS FILE. On top of that it sends a REAL push on every conflict edge /
#   RECOVERED via the SAME notifier the a11oy-uptime monitor uses
#   (/usr/local/sbin/a11oy-uptime-notify -> ntfy / Telegram / Slack-Discord
#   webhook), wired through NOTIFY_CMD in the service unit. NOTIFY_CMD reads the
#   alert text on stdin and is FAIL-SOFT: a missing/broken channel never hides
#   the edge (always recorded in the log). The monitor fires only on the
#   healthy->conflict EDGE and on RECOVERED (persisting conflict is de-duped), so
#   it respects the standing "recurring alerts = the owner only" policy by
#   construction — see memory sms-alerts-on-hetzner.md.
#
# Idempotent and safe to run on a short timer, and as an ExecStartPost hook right
# after every szl-box-sync-pull run.
set -uo pipefail

# ---- config (overridable via env for testing) -------------------------------
REPO="${REPO:-${SZL_BOX_SYNC_REPO:-/opt/szl/szl-uds-deployment}}"
# The exact label szl-box-sync's reset_in_line uses for its autostash. We match
# ONLY these so a sibling's deliberate manual `git stash` is never mistaken for a
# sync-created conflict stash.
STASH_MATCH="${STASH_MATCH:-szl-box-sync autostash}"

STATE_DIR="${STATE_DIR:-/var/lib/szl-box-sync-conflict}"
LOG_DIR="${LOG_DIR:-/var/log/szl-box-sync-conflict}"
LOG="${LOG:-$LOG_DIR/szl-box-sync-conflict.log}"
STATUS="${STATUS:-$STATE_DIR/status.json}"
SIG_FILE="${SIG_FILE:-$STATE_DIR/problem.sig}"
NOTIFY_CMD="${NOTIFY_CMD:-}"          # optional external notifier (stdin = message)
ALERT_PREFIX="${ALERT_PREFIX:-}"      # e.g. "[TEST-ignore] " to test without alarming

mkdir -p "$STATE_DIR" "$LOG_DIR" 2>/dev/null

now_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)
log() { printf '%s %s\n' "$now_iso" "$*" >>"$LOG"; }

# All git access is read-only and runs through this wrapper. safe.directory keeps
# git from refusing on the shared root's ownership; -C scopes it to the tree.
g() { git -c safe.directory="$REPO" -C "$REPO" "$@"; }

json_escape() {
  printf '%s' "$1" | python3 -c 'import json,sys; sys.stdout.write(json.dumps(sys.stdin.read()))' 2>/dev/null && return 0
  local s="$1"; s=${s//\\/\\\\}; s=${s//\"/\\\"}; s=${s//$'\n'/\\n}; printf '"%s"' "$s"
}

# ---- 0. repo sanity (fail-soft, never a false page on our own misconfig) -----
if [ ! -d "$REPO/.git" ]; then
  log "WARN repo not found at $REPO (set REPO/SZL_BOX_SYNC_REPO) — nothing to check"
  {
    printf '{\n'
    printf '  "checked_at": "%s",\n' "$now_iso"
    printf '  "repo": "%s",\n' "$REPO"
    printf '  "overall": "NOREPO",\n'
    printf '  "unmerged_count": 0,\n'
    printf '  "stash_count": 0,\n'
    printf '  "alerting": false\n'
    printf '}\n'
  } >"$STATUS.tmp" && mv "$STATUS.tmp" "$STATUS"
  log "STATE overall=NOREPO repo=$REPO"
  exit 0
fi

# ---- 1. unmerged (UU) paths -------------------------------------------------
unmerged="$(g ls-files -u 2>/dev/null | awk '{print $4}' | sort -u)"
unmerged_count=0
[ -n "$unmerged" ] && unmerged_count=$(printf '%s\n' "$unmerged" | grep -c . )

# ---- 2. szl-box-sync autostash entries still retained -----------------------
stashes="$(g stash list 2>/dev/null | grep -F "$STASH_MATCH" || true)"
stash_count=0
[ -n "$stashes" ] && stash_count=$(printf '%s\n' "$stashes" | grep -c . )

# ---- build the problem set --------------------------------------------------
problems=()
if [ "$unmerged_count" -gt 0 ]; then
  u_list=$(printf '%s' "$unmerged" | tr '\n' ' '); u_list="${u_list% }"
  problems+=("$unmerged_count unmerged (UU) path(s) after szl-box-sync: $u_list")
fi
if [ "$stash_count" -gt 0 ]; then
  s_list=$(printf '%s' "$stashes" | sed 's/^[[:space:]]*//' | tr '\n' '|'); s_list="${s_list%|}"
  problems+=("$stash_count retained '$STASH_MATCH' stash entry(ies): $s_list")
fi

# ---- write the status file (always) ----------------------------------------
overall="OK"; [ "${#problems[@]}" -gt 0 ] && [ -n "${problems[0]:-}" ] && overall="CONFLICT"
{
  printf '{\n'
  printf '  "checked_at": "%s",\n' "$now_iso"
  printf '  "repo": "%s",\n' "$REPO"
  printf '  "overall": "%s",\n' "$overall"
  printf '  "unmerged_count": %s,\n' "$unmerged_count"
  printf '  "unmerged": ['
  first=1
  while IFS= read -r p; do
    [ -n "$p" ] || continue
    [ $first -eq 0 ] && printf ', '; first=0
    printf '%s' "$(json_escape "$p")"
  done <<EOF
$unmerged
EOF
  printf '],\n'
  printf '  "stash_count": %s,\n' "$stash_count"
  printf '  "stashes": ['
  first=1
  while IFS= read -r p; do
    [ -n "$p" ] || continue
    [ $first -eq 0 ] && printf ', '; first=0
    printf '%s' "$(json_escape "$(printf '%s' "$p" | sed 's/^[[:space:]]*//')")"
  done <<EOF
$stashes
EOF
  printf '],\n'
  printf '  "alerting": %s\n' "$( [ "$overall" = CONFLICT ] && echo true || echo false )"
  printf '}\n'
} >"$STATUS.tmp" && mv "$STATUS.tmp" "$STATUS"

# ---- transition de-dup + alert ---------------------------------------------
prev_sig=""; [ -r "$SIG_FILE" ] && prev_sig=$(cat "$SIG_FILE" 2>/dev/null)

# push(): fire the external notifier (stdin = message). Fail-soft — a missing or
# broken notifier never hides the edge, which is always recorded in the log too.
push() {
  [ -z "$NOTIFY_CMD" ] && return 0
  printf '%s%s\n' "$ALERT_PREFIX" "$1" | $NOTIFY_CMD >>"$LOG" 2>&1 \
    || log "WARN notifier '$NOTIFY_CMD' failed"
}

emit_alert() {
  local body="$1"
  log "ALERT $body"
  push "$body"
}

if [ "$overall" = OK ]; then
  if [ -n "$prev_sig" ]; then
    rec="box szl-uds-deployment tree clean again (no UU paths, no retained '$STASH_MATCH' stash)"
    log "RECOVERED $rec"
    push "szl-box-sync RECOVERED: $rec"
    rm -f "$SIG_FILE"
  fi
else
  problem_text=$(printf '%s; ' "${problems[@]}"); problem_text="${problem_text%; }"
  cur_sig=$(printf '%s\n' "${problems[@]}" | sort | md5sum | awk '{print $1}')
  if [ "$cur_sig" = "$prev_sig" ]; then
    log "(persisting) $problem_text"
  else
    emit_alert "szl-box-sync auto-sync left the box tree half-merged: $problem_text. The sync is non-destructive (no work lost) but the tree needs a human to resolve the conflict and clear the stash — DO NOT blind-drop. Inspect: szl-box-sync status; git -C $REPO status; git -C $REPO stash list"
    printf '%s' "$cur_sig" >"$SIG_FILE"
  fi
fi

# heartbeat: prove the monitor is alive + carry an OK/CONFLICT history.
log "STATE overall=$overall unmerged=$unmerged_count stash=$stash_count repo=$REPO"
exit 0
