#!/usr/bin/env bash
#
# szl-receipts-orphan-watch — flag any ORPHANED duplicate receipts server on the
# k3d uds-szl-demo cluster (box 167.233.50.75), so an unsigned, untracked copy
# eating CPU on an already-loaded 2-vCPU node gets noticed automatically instead
# of being hunted down by hand (as in Task #283).
#
# WHY: a hand-made scratch namespace (e.g. szl-receipts-demo) keeps reappearing
# after each cluster rebuild. It runs a szl-receipts-server workload but is owned
# by NOTHING — no Helm release, no zarf package, no UDS Package, no
# VirtualService — so it holds no durable data, signs nothing, and just burns CPU.
# The canonical szl-receipts (Helm/zarf/UDS-Package/VS owned) must never be
# flagged; only untracked duplicates.
#
# WHAT IT DETECTS: every namespace running a receipts-server Deployment (matched
# by name == szl-receipts-server OR a container image matching IMAGE_MATCH), minus
# the canonical namespace, that is NOT owned by ANY of:
#   - Helm   : deploy carries app.kubernetes.io/managed-by=Helm or a
#              meta.helm.sh/release-name annotation, OR `helm list -A` shows a
#              release in that namespace (this is also how zarf/UDS deploy here,
#              so it doubles as the `zarf package list` / UDS ownership signal).
#   - UDS    : a packages.uds.dev CR exists in the namespace.
#   - Istio  : a VirtualService exists in the namespace.
# Any receipts-server namespace with none of those = an ORPHAN -> alert.
#
# It NEVER deletes anything (an orphan is sometimes a teammate's live scratch —
# deletion stays a human call). It only logs + edge-pushes.
#
# EDGE-triggered + de-duped via a state file: pushes the notifier once on the
# healthy->problem edge (a new orphan appears) and once on RECOVERED (all orphans
# gone), never every cycle (honours "recurring alerts = one ping").
#
# FAIL-SAFE: this guard biases hard against false alarms. The cluster being
# intentionally stopped (k3d down), unreachable, OR any ownership probe erroring
# transiently (API hiccup, RBAC, CRD/`helm list` failure) = a true no-op: status
# UNKNOWN, last_status left UNTOUCHED, exit 0, NO alert. A namespace is only ever
# flagged once its non-ownership is positively confirmed. Mirrors the
# receipt-chain-watch / szl-ns-scratch-watch guard pattern.
#
# Driven by szl-receipts-orphan-watch.timer (every 10 min).
set -uo pipefail

CLUSTER="${SZL_RECEIPTS_CLUSTER:-uds-szl-demo}"
CANONICAL_NS="${SZL_RECEIPTS_CANONICAL_NS:-szl-receipts}"
# A Deployment is a receipts-server workload if its name is this OR any container
# image matches IMAGE_MATCH (catches a renamed copy / local v0.4.0-src builds).
DEPLOY_NAME="${SZL_RECEIPTS_DEPLOY_NAME:-szl-receipts-server}"
IMAGE_MATCH="${SZL_RECEIPTS_IMAGE_MATCH:-receipts-server}"

STATE_DIR="${STATE_DIR:-/var/lib/szl-receipts-orphan-watch}"
LOG_DIR="${LOG_DIR:-/var/log/szl-receipts-orphan-watch}"
LAST_FILE="${LAST_FILE:-$STATE_DIR/last_status}"
STATUS="${STATUS:-$STATE_DIR/status.json}"
LOG="${LOG:-$LOG_DIR/szl-receipts-orphan-watch.log}"
LOCK="${LOCK:-$STATE_DIR/lock}"

# Notifier: stdin = message. Default to the box's working push channel.
NOTIFY_CMD="${NOTIFY_CMD:-/usr/local/sbin/a11oy-uptime-notify}"
ALERT_PREFIX="${ALERT_PREFIX:-}"

mkdir -p "$STATE_DIR" "$LOG_DIR" 2>/dev/null

log() { printf '%s %s\n' "$(date -u +%FT%TZ)" "$1" >>"$LOG" 2>/dev/null; }

# Single-flight: never let two overlapping runs read/notify/write state at once.
if command -v flock >/dev/null 2>&1; then
  exec 9>"$LOCK" 2>/dev/null || true
  flock -n 9 2>/dev/null || { log "INFO another run holds the lock — skip"; exit 0; }
fi

notify() {
  [ -z "$NOTIFY_CMD" ] && return 0
  printf '%s%s\n' "$ALERT_PREFIX" "$1" | $NOTIFY_CMD >>"$LOG" 2>&1 \
    || log "WARN notifier '$NOTIFY_CMD' failed (alert was logged only)"
}

# Atomic writers (tmp + rename) so an interrupted run never leaves partial state.
write_status() {
  # $1 = overall (OK|ALERT|UNKNOWN)  $2 = reason
  local tmp="$STATUS.tmp.$$"
  printf '{"overall":"%s","reason":"%s","checked_at":"%s","cluster":"%s"}\n' \
    "$1" "$(printf '%s' "$2" | sed 's/"/\\"/g')" "$(date -u +%FT%TZ)" "$CLUSTER" \
    >"$tmp" 2>/dev/null && mv -f "$tmp" "$STATUS" 2>/dev/null || rm -f "$tmp" 2>/dev/null
}
set_last() {
  # $1 = OK|ALERT
  local tmp="$LAST_FILE.tmp.$$"
  printf '%s\n' "$1" >"$tmp" 2>/dev/null && mv -f "$tmp" "$LAST_FILE" 2>/dev/null || rm -f "$tmp" 2>/dev/null
}

# ---- Resolve cluster; no-op if it is down (intentionally stopped) -----------
KC="$(k3d kubeconfig write "$CLUSTER" 2>/dev/null)" || { log "INFO cluster '$CLUSTER' absent — skip"; write_status UNKNOWN "cluster absent"; exit 0; }
export KUBECONFIG="$KC"
kubectl --request-timeout=20s get --raw='/readyz' >/dev/null 2>&1 \
  || { log "INFO cluster '$CLUSTER' not reachable — skip"; write_status UNKNOWN "cluster unreachable"; exit 0; }

# ---- Enumerate every Deployment: ns, name, images, helm-ownership signals ----
# Tab-separated: ns \t name \t images(space-joined) \t managed-by \t helm-release
rows="$(kubectl --request-timeout=20s get deploy -A -o jsonpath='{range .items[*]}{.metadata.namespace}{"\t"}{.metadata.name}{"\t"}{range .spec.template.spec.containers[*]}{.image}{" "}{end}{"\t"}{.metadata.labels.app\.kubernetes\.io/managed-by}{"\t"}{.metadata.annotations.meta\.helm\.sh/release-name}{"\n"}{end}' 2>/dev/null)" \
  || { log "WARN kubectl get deploy failed — skip"; write_status UNKNOWN "kubectl error"; exit 0; }

# Namespaces that have ANY Helm release (covers zarf- and UDS-deployed releases).
# This is a SECONDARY signal; the per-deploy managed-by label / release-name
# annotation in $rows is the primary, error-proof helm signal. If `helm list`
# itself errors we mark the run degraded so a candidate is never flagged solely
# because this lookup was unavailable.
helm_ns=""; helm_ok=1
helm_ns="$(helm list -A 2>/dev/null | awk 'NR>1{print $2}' | sort -u)" || helm_ok=0
# `helm list` can exit 0 yet still have failed to reach the API; treat an empty
# result as authoritative only when the command clearly succeeded.

is_helm_ns()  { [ "$helm_ok" = 1 ] && printf '%s\n' "$helm_ns" | grep -qx "$1"; }

# Tri-state existence probe: echoes yes|no|err. "err" (any kubectl failure OR a
# missing CRD) means we could NOT determine ownership -> caller must NOT flag.
resource_in_ns() {
  # $1 = resource  $2 = namespace
  local out rc
  out="$(kubectl --request-timeout=20s get "$1" -n "$2" --no-headers 2>/dev/null)"; rc=$?
  if [ "$rc" -ne 0 ]; then echo err; return 0; fi
  if printf '%s' "$out" | grep -q .; then echo yes; else echo no; fi
}

orphans=""
degraded=0   # set when ownership for >=1 candidate could not be determined
indeterminate=""

# De-dupe candidate namespaces first (a ns may have >1 matching deploy).
cand_ns="$(printf '%s\n' "$rows" | while IFS=$'\t' read -r ns name images managedby relname; do
  [ -z "$ns" ] && continue
  [ "$ns" = "$CANONICAL_NS" ] && continue
  if [ "$name" = "$DEPLOY_NAME" ] || printf '%s' "$images" | grep -q "$IMAGE_MATCH"; then
    printf '%s\n' "$ns"
  fi
done | sort -u)"

for ns in $cand_ns; do
  [ -z "$ns" ] && continue

  # 1) Primary helm signal straight off this ns's matching deploy(s) — reliable,
  #    independent of `helm list` (catches the canonical szl-receipts too).
  deploy_helm="$(printf '%s\n' "$rows" | awk -F'\t' -v n="$ns" '$1==n && ($4=="Helm" || $5!=""){print "yes"; exit}')"
  if [ "$deploy_helm" = "yes" ] || is_helm_ns "$ns"; then
    log "TRACKED ns=$ns (helm owned) — not an orphan"
    continue
  fi

  # 2) UDS Package ownership.
  up="$(resource_in_ns packages.uds.dev "$ns")"
  if [ "$up" = "yes" ]; then log "TRACKED ns=$ns (uds package) — not an orphan"; continue; fi
  if [ "$up" = "err" ]; then
    degraded=1; indeterminate="${indeterminate:+$indeterminate }$ns"
    log "INDETERMINATE ns=$ns — UDS-package probe errored, NOT flagging"; continue
  fi

  # 3) Istio VirtualService ownership.
  vp="$(resource_in_ns virtualservices.networking.istio.io "$ns")"
  if [ "$vp" = "yes" ]; then log "TRACKED ns=$ns (virtualservice) — not an orphan"; continue; fi
  if [ "$vp" = "err" ]; then
    degraded=1; indeterminate="${indeterminate:+$indeterminate }$ns"
    log "INDETERMINATE ns=$ns — VirtualService probe errored, NOT flagging"; continue
  fi

  # 4) If `helm list` was unavailable we could not fully rule out helm ownership
  #    for a ns whose deploy carries no managed-by label — fail safe, don't flag.
  if [ "$helm_ok" != 1 ]; then
    degraded=1; indeterminate="${indeterminate:+$indeterminate }$ns"
    log "INDETERMINATE ns=$ns — 'helm list' unavailable, NOT flagging"; continue
  fi

  # Confirmed: owned by NOTHING.
  orphans="${orphans:+$orphans }$ns"
done

count=0
[ -n "$orphans" ] && count="$(printf '%s\n' $orphans | grep -c .)"
list_csv="$(printf '%s' "$orphans" | tr ' ' '\n' | paste -sd ', ' - 2>/dev/null)"
ind_csv="$(printf '%s' "$indeterminate" | tr ' ' '\n' | paste -sd ', ' - 2>/dev/null)"

# ---- Decide + edge-trigger --------------------------------------------------
prev="$(cat "$LAST_FILE" 2>/dev/null || echo OK)"

if [ "$count" -gt 0 ] 2>/dev/null; then
  write_status ALERT "$count orphaned receipts-server namespace(s): ${list_csv}"
  log "STATE ALERT count=$count :: $list_csv"
  if [ "$prev" != "ALERT" ]; then
    notify "ALERT: $count orphaned receipts-server namespace(s) on $CLUSTER NOT owned by Helm/zarf/UDS-Package/VirtualService (canonical '$CANONICAL_NS' excluded): ${list_csv}. These run unsigned, hold no durable data, and burn CPU on the 2-vCPU node. Investigate and remove by hand if they're stray (e.g. 'kubectl delete ns <ns>') — this guard never deletes."
    log "EDGE OK->ALERT notified"
  else
    log "DEDUP still ALERT — no re-notify"
  fi
  set_last ALERT
elif [ "$degraded" = 1 ]; then
  # Could not positively confirm ownership for >=1 candidate -> never alarm,
  # never reset an existing ALERT. Leave last_status as-is, just record UNKNOWN.
  write_status UNKNOWN "ownership undetermined for: ${ind_csv} (probe error) — skipped"
  log "STATE UNKNOWN degraded indeterminate=$ind_csv (last_status left as '$prev')"
else
  write_status OK "no orphaned receipts-server namespaces"
  log "STATE OK count=0"
  if [ "$prev" = "ALERT" ]; then
    notify "RECOVERED: no orphaned receipts-server namespaces remain on $CLUSTER (all stray duplicates removed or now tracked)."
    log "EDGE ALERT->OK recovered, notified"
  fi
  set_last OK
fi

exit 0
