#!/usr/bin/env bash
# a11oy-rebuild — rebuild the a11oy.net Docker image from the PUBLISHED GitHub
# source of truth (szl-holdings/a11oy), discarding any local working-tree drift,
# then recreate the running container. Idempotent and safe to re-run.
#
# WHY THIS EXISTS:
#   The box build tree (/opt/szl/a11oy) is routinely BEHIND GitHub main (stale
#   remote-tracking ref + hand-patched files). The Docker image used to be built
#   straight from that drifting tree, so the live a11oy.net image could silently
#   diverge from the published source. This wrapper guarantees every rebuild
#   starts from a clean checkout of origin/main, so the running container always
#   reflects what is published. DO NOT hand-patch the tree and `docker build`
#   directly — run this instead.
#
# USAGE:
#   a11oy-rebuild           # fetch+reset to origin/main, build, recreate, verify
#   a11oy-rebuild --verify-only   # just verify the running image vs origin/main
#
# OVERRIDES (env): A11OY_REPO_DIR A11OY_BRANCH A11OY_IMAGE A11OY_CONTAINER A11OY_PORT_BIND
set -uo pipefail

REPO_DIR="${A11OY_REPO_DIR:-/opt/szl/a11oy}"
BRANCH="${A11OY_BRANCH:-main}"
IMAGE="${A11OY_IMAGE:-a11oy:local}"
CONTAINER="${A11OY_CONTAINER:-a11oy}"
PORT_BIND="${A11OY_PORT_BIND:-127.0.0.1:7861:7860}"
# Published Hugging Face Space that holds the feature files never back-ported to
# GitHub (real 3-way drift). Public repo → cloned anonymously, LFS smudge skipped
# (the overlay files are plain .py/.json/.js/.txt, never LFS).
HF_SPACE_URL="${A11OY_HF_SPACE_URL:-https://huggingface.co/spaces/szlholdings/a11oy}"
HF_CACHE_DIR="${A11OY_HF_CACHE_DIR:-/opt/szl/hf-a11oy}"
BACKUP_DIR="/root/a11oy-build-backups"
TS="$(date +%Y%m%d-%H%M%S)"

log(){ echo "[a11oy-rebuild $(date +%H:%M:%S)] $*"; }
fail(){ echo "[a11oy-rebuild] FATAL: $*" >&2; exit "${2:-1}"; }

# Compare the front-door files baked into $IMAGE against origin/$BRANCH byte-for-byte.
# Dockerfile maps: pages/  -> /app/pages/ ,  console/ -> /app/static/
verify(){
  local rc=0 rp ip want got
  for pair in "pages/console.html:/app/pages/console.html" "console/index.html:/app/static/index.html"; do
    rp="${pair%%:*}"; ip="${pair##*:}"
    want="$(git show "origin/$BRANCH:$rp" 2>/dev/null | md5sum | awk '{print $1}')"
    got="$(docker run --rm --entrypoint cat "$IMAGE" "$ip" 2>/dev/null | md5sum | awk '{print $1}')"
    if [ -n "$want" ] && [ "$want" = "$got" ]; then
      log "VERIFY OK   $rp == image:$ip  ($want)"
    else
      log "VERIFY FAIL $rp ($want) != image:$ip ($got)"; rc=1
    fi
  done
  return $rc
}

# Refresh the cached HF Space clone and overlay any Dockerfile COPY source that is
# missing from the GitHub build context (the ~19 feature files that live only on
# the published HF Space). Fails loudly rather than shipping a degraded image.
overlay_hf(){
  local missing=()
  while read -r src; do
    [ -z "$src" ] && continue
    local s="${src%/}"
    [ -e "$s" ] || missing+=("$s")
  done < <(grep -E '^COPY ' "$REPO_DIR/Dockerfile" | awk '{print $2}')

  if [ "${#missing[@]}" -eq 0 ]; then
    log "Overlay: no missing COPY sources — GitHub main is self-sufficient."
    return 0
  fi
  log "Overlay: ${#missing[@]} COPY source(s) missing from GitHub build context; sourcing from published HF Space."

  if [ -d "$HF_CACHE_DIR/.git" ]; then
    log "Overlay: refreshing HF cache $HF_CACHE_DIR ..."
    ( cd "$HF_CACHE_DIR" && GIT_LFS_SKIP_SMUDGE=1 GIT_TERMINAL_PROMPT=0 git fetch --depth 1 origin "$BRANCH" \
        && git reset --hard "origin/$BRANCH" && git clean -fd ) \
      || fail "HF cache refresh failed" 9
  else
    log "Overlay: cloning HF Space $HF_SPACE_URL (anon, LFS-skip) ..."
    GIT_LFS_SKIP_SMUDGE=1 GIT_TERMINAL_PROMPT=0 git clone --depth 1 -b "$BRANCH" "$HF_SPACE_URL" "$HF_CACHE_DIR" \
      || fail "HF Space clone failed" 9
  fi

  local still=()
  for s in "${missing[@]}"; do
    if [ -e "$HF_CACHE_DIR/$s" ]; then
      mkdir -p "$REPO_DIR/$(dirname "$s")"
      cp -a "$HF_CACHE_DIR/$s" "$REPO_DIR/$s"
      log "Overlay: + $s"
    else
      still+=("$s")
    fi
  done
  if [ "${#still[@]}" -gt 0 ]; then
    printf '   STILL-MISSING: %s\n' "${still[@]}" >&2
    fail "overlay incomplete — ${#still[@]} COPY source(s) absent from BOTH GitHub main and the HF Space (refusing to ship a degraded image)" 10
  fi
  log "Overlay: all missing COPY sources resolved from the published HF Space."
}

cd "$REPO_DIR" || fail "$REPO_DIR not found" 2
mkdir -p "$BACKUP_DIR"

log "Fetching origin/$BRANCH ..."
git fetch --no-tags origin "$BRANCH" || fail "git fetch failed" 3

if [ "${1:-}" = "--verify-only" ]; then
  log "verify-only: comparing running $IMAGE against origin/$BRANCH"
  verify && { log "verify-only: PASS"; exit 0; } || { log "verify-only: FAIL"; exit 5; }
fi

# Never silently lose local work: snapshot any uncommitted drift before discarding.
if ! git diff --quiet || ! git diff --cached --quiet; then
  git diff HEAD > "$BACKUP_DIR/uncommitted-$TS.patch" 2>/dev/null || true
  log "Backed up uncommitted drift -> $BACKUP_DIR/uncommitted-$TS.patch"
fi

log "Resetting working tree to origin/$BRANCH (discarding drift) ..."
git reset --hard "origin/$BRANCH" || fail "git reset failed" 6
git clean -fd || true

HEAD_SHA="$(git rev-parse --short HEAD)"
log "Build source pinned to published origin/$BRANCH = $HEAD_SHA"

overlay_hf

log "docker build -t $IMAGE . (this can take several minutes) ..."
if docker build -t "$IMAGE" . ; then
  log "docker build OK -> $IMAGE"
else
  fail "docker build failed (note: a non-fatal llama-cpp-python wheel ERROR is expected; only treat a non-zero build rc as failure)" 4
fi

log "Recreating container $CONTAINER ..."
docker rm -f "$CONTAINER" >/dev/null 2>&1 || true
docker run -d --name "$CONTAINER" --restart unless-stopped -p "$PORT_BIND" "$IMAGE" >/dev/null \
  || fail "docker run failed" 7

sleep 3
log "Container state: $(docker inspect -f '{{.State.Status}}' "$CONTAINER" 2>/dev/null)"

log "Verifying baked front-door files match published origin/$BRANCH ..."
if verify; then
  log "DONE — $CONTAINER running from published $BRANCH@$HEAD_SHA, front door matches source."
else
  fail "rebuild completed but front-door verification FAILED" 8
fi
