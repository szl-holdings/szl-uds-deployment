# receipt-flood-watch tunables for the uds-tenant (multi-node) cluster.
#
# CLUSTER is already set to the systemd instance name (uds-tenant) by
# receipt-flood-watch@uds-tenant.service — override here only if the k3d cluster
# is named differently. For a cluster that is NOT a local k3d cluster resolvable
# by name (e.g. an externally-managed multi-node cluster) point KUBECONFIG_FILE
# at its kubeconfig; when set it is used verbatim instead of `k3d kubeconfig
# write $CLUSTER`.
#
# Defaults below match the szl-receipts deployment; uncomment to override.
#KUBECONFIG_FILE=/root/.kube/uds-tenant.config
#RNS=szl-receipts
#RX_SELECTOR=app.kubernetes.io/name=szl-receipts-server
#RX_CONTAINER=receipts-server
#METRICS_PORT=8080
# Sustained chain growth at/above this many receipts/min is an ALERT.
#FLOOD_PER_MIN=120
#MIN_INTERVAL_SECS=60
