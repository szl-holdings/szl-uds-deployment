{
  "name": "szl-receipt-policy",
  "version": "0.1.0",
  "description": "Pepr policy module: emit DSSE governance receipts on every Kubernetes Deployment/Job apply",
  "license": "Apache-2.0",
  "keywords": [
    "pepr",
    "k8s",
    "governance",
    "receipts",
    "dsse",
    "szl",
    "uds"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "pepr": {
    "name": "szl-receipt-policy",
    "uuid": "szl",
    "onError": "ignore",
    "logLevel": "info",
    "env": {
      "SZL_MIN_RECEIPT_INTERVAL_MS": "2000",
      "SZL_DEDUP_MAX_ENTRIES": "10000"
    },
    "alwaysIgnore": {
      "namespaces": [
        "zarf",
        "kube-system",
        "kube-public",
        "kube-node-lease",
        "pepr-system",
        "szl-receipts"
      ]
    },
    "watch": {
      "alwaysIgnore": {
        "namespaces": [
          "zarf",
          "kube-system"
        ]
      }
    }
  },
  "scripts": {
    "build": "npx pepr build",
    "deploy": "npx pepr deploy --confirm",
    "dev": "npx pepr dev",
    "test": "npx pepr validate"
  },
  "dependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/command-line-args": "^5.2.3",
    "@types/express": "^5.0.6",
    "@types/json-pointer": "^1.0.34",
    "@types/json-schema": "^7.0.15",
    "@types/node-forge": "^1.3.14",
    "@types/ramda": "^0.31.1",
    "@types/readable-stream": "^4.0.23",
    "@types/urijs": "^1.19.26",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.9",
    "command-line-args": "^6.0.2",
    "commander": "^15.0.0",
    "eslint": "^10.5.0",
    "express": "^5.2.1",
    "fast-check": "^4.8.0",
    "fast-json-patch": "^3.1.1",
    "globals": "^17.6.0",
    "http-status-codes": "^2.3.0",
    "husky": "^9.1.7",
    "js-yaml": "^4.2.0",
    "json-pointer": "^0.6.2",
    "kubernetes-fluent-client": "^3.11.7",
    "node-forge": "^1.4.0",
    "pepr": "1.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "prom-client": "^15.1.3",
    "prompts": "^2.4.2",
    "quicktype-core": "^23.2.6",
    "ramda": "^0.32.0",
    "readable-stream": "^4.7.0",
    "selfsigned": "^5.5.0",
    "shellcheck": "^4.1.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "undici": "^8.5.0",
    "urijs": "^1.19.11",
    "uuid": "^14.0.0",
    "vitest": "^4.1.8",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@felipecrs/decompress-tarxz": "5.0.6",
    "@xhmikosr/decompress-unzip": "8.2.0",
    "@xhmikosr/decompress-tar": "9.0.1",
    "esbuild": "0.28.1",
    "js-yaml@<4.2.0": "4.2.0"
  }
}
